/* AshiChat TUI Stylesheet — Pure Black, ASCII-safe */

Screen {
    background: #000000;
    color: #ffffff;
}

Header {
    background: #000000;
    color: #ffffff;
    border-bottom: solid #222222;
}

Footer {
    background: #000000;
    color: #aaaaaa;
}

/* Sidebar */
Sidebar {
    width: 28;
    dock: left;
    background: #000000;
    border-right: solid #333333;
    padding: 1;
}

.sidebar-title {
    text-style: bold;
    color: #ffffff;
    padding-bottom: 1;
}

#contact-search {
    background: #0a0a0a;
    color: #dddddd;
    border: solid #222222;
    margin-bottom: 1;
}

#contact-list {
    background: #000000;
    border: none;
}

#contact-list > ListItem {
    padding: 0 1;
    height: 1;
}

#contact-list > ListItem:hover {
    background: #222222;
}

/* Chat view */
ChatView {
    background: #000000;
    padding: 1;
    border: none;
}

#message-container {
    background: #000000;
    padding: 0 1;
    border: none;
    scrollbar-color: #333333;
    scrollbar-color-hover: #555555;
}

.msg-header {
    color: #bbbbbb;
    text-style: bold;
    padding-bottom: 1;
}

.msg-incoming {
    color: #dcdcdc;
}

.msg-outgoing {
    color: #8fd7ff;
}

.msg-system {
    color: #8f8f8f;
}

/* Message input */
MessageInput {
    dock: bottom;
    height: 3;
    padding: 0 1;
    background: #000000;
    border-top: solid #333333;
    border-bottom: solid #222222;
}

#msg-input {
    background: #000000;
    color: #ffffff;
    border: none;
}

#msg-input:focus {
    border: none;
}
